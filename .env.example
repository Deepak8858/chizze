# ══════════════════════════════════════════
# Chizze — Flutter Build Environment
# ══════════════════════════════════════════
# These values are passed via --dart-define at build time.
# They are NOT loaded from this file automatically.
#
# Dev:
#   flutter run
#
# Staging:
#   flutter run --dart-define=ENV=staging --dart-define=API_URL=https://staging.chizze.in/api/v1
#
# Production:
#   flutter build apk --dart-define=ENV=production --dart-define=API_URL=https://api.chizze.in/api/v1
#
# Android real device (dev):
#   flutter run --dart-define=DEV_API_URL=http://YOUR_LOCAL_IP:8080/api/v1
# ══════════════════════════════════════════

ENV=dev                           # dev | staging | production
API_URL=                          # Override API base URL (optional)
DEV_API_URL=http://10.0.2.2:8080/api/v1  # Dev only — emulator default

# Appwrite (hardcoded in lib/config/environment.dart)
# APPWRITE_PROJECT_ID=6993347c0006ead7404d
# APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
