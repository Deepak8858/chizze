# ══════════════════════════════════════════
# Chizze Deploy — Production Environment
# ══════════════════════════════════════════
# Copy to .env.prod and fill in real values
# NEVER commit .env.prod to git
# ══════════════════════════════════════════

# ─── Server ───
PORT=8080
GIN_MODE=release
ALLOWED_ORIGINS=https://devdeepak.me,https://www.devdeepak.me,https://api.devdeepak.me

# ─── Appwrite Cloud ───
APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=6993347c0006ead7404d
APPWRITE_API_KEY=your_production_appwrite_api_key
APPWRITE_DATABASE_ID=chizze_db

# ─── Razorpay (Production keys) ───
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_production_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_production_webhook_secret

# ─── Redis ───
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
REDIS_PASSWORD=generate_a_strong_password_here

# ─── JWT ───
JWT_SECRET=generate_a_64_char_random_string_here

# ─── Docker Image ───
DOCKER_IMAGE=ghcr.io/your-org/chizze-api:latest
APP_VERSION=1.0.0

# ─── Monitoring (Optional) ───
# SENTRY_DSN=https://xxxx@sentry.io/yyyy
# LOG_LEVEL=info

# ─── Firebase Cloud Messaging ───
# FCM_SERVER_KEY=your_fcm_server_key
# FCM_PROJECT_ID=your_firebase_project_id
